  "widgetMetadata": {
    "instructions": "Each entry under `widgets` describes one chart/widget rendered on this page of the Israeli Ecosystem dashboard. Descriptions are result-agnostic: they explain what the visualization shows and how to interpret it, not the specific numbers. The `dataPaths` array on each entry lists dot-notation paths inside this same JSON file where the underlying data for that widget lives (e.g. \"kpis.patentingStartups\" or \"ipIntensity.items\") When summarizing or answering questions about a number from this snapshot, locate the relevant widget(s) by `dataPaths` and quote the corresponding `description` to explain the metric. Widgets that have a 10 year trend usually show the total overall (across all years) and you get the exact data for each year in the past 10 years. The 10 year data do not add up to the total of course",
    "widgets": {
      "founders:kpi-total-founders": {
        "title": "Total Founders",
        "description": "Total number of founders of Israeli startups with a known gender (Male or Female). Each founder is counted once per startup they founded, so a serial founder of 3 startups counts 3 times. The sparkline shows new founders by their startup founding year over the past 10 years.",
        "dataPaths": [
          "composition.male",
          "composition.female",
          "genderOverTime.years",
          "genderOverTime.male",
          "genderOverTime.female"
        ]
      },
      "founders:kpi-male-founders": {
        "title": "Male Founders",
        "description": "Total number of male founders across Israeli startups, counted per founder-startup pair. The sparkline shows new male founders by startup founding year over the past 10 years.",
        "dataPaths": [
          "composition.male",
          "genderOverTime.years",
          "genderOverTime.male"
        ]
      },
      "founders:kpi-female-founders": {
        "title": "Female Founders",
        "description": "Total number of female founders across Israeli startups, counted per founder-startup pair. The sparkline shows new female founders by startup founding year over the past 10 years.",
        "dataPaths": [
          "composition.female",
          "genderOverTime.years",
          "genderOverTime.female"
        ]
      },
      "founders:gender-over-time": {
        "title": "Gender Composition Over Time",
        "description": "Share of male vs female founders for startups founded in each of the past 10 years. The white boundary line and the percentage labels show the male share. The blue area below the line is the male portion, the pink area above is the female portion. Hover a year to see absolute counts behind the share.",
        "dataPaths": [
          "genderOverTime.years",
          "genderOverTime.male",
          "genderOverTime.female"
        ]
      },
      "founders:team-gender-donut": {
        "title": "Team Gender Composition",
        "description": "Distribution of Israeli startup founding teams by their gender mix. Each team is bucketed by male-founder ratio: Only Male (100%), Mostly Male (above 60%), Mixed (40 to 60%), Mostly Female (below 40%), Only Female (0%). The center shows the total number of teams or the value of the hovered slice.",
        "dataPaths": [
          "teamComposition"
        ]
      },
      "founders:team-size": {
        "title": "Team Size",
        "description": "Distribution of Israeli startup founding teams by number of founders, bucketed into 1, 2, 3, and 4 or more. Bar width is proportional to the count of teams in that bucket. Hover a row for the absolute count and share of all teams.",
        "dataPaths": [
          "teamSize.totalTeams",
          "teamSize.buckets"
        ]
      },
      "founders:team-dna": {
        "title": "DNA Composition",
        "description": "Mix of Technical and Business founders inside Israeli startup founding teams, only computed for teams of 2 or 3 founders with known DNA. Each row is one possible composition with the number of teams and their share out of all Israeli startup founding teams.",
        "dataPaths": [
          "teamDna.totalTeams",
          "teamDna.items"
        ]
      },
      "founders:continuous-distribution": {
        "title": "The Average Founder",
        "description": "For each continuous founder variable the left column shows the average value overall and its 10 year trend by startup founding year. The right column shows the full distribution as a histogram with a box plot on top: whiskers cover P10 to P90, the box covers P25 to P75, the dot is the median, and the white dashed line is the average.",
        "dataPaths": [
          "continuousVariables.years",
          "continuousVariables.variables"
        ]
      },
      "founders:binary-indicators": {
        "title": "Founder Indicators",
        "description": "Share of Israeli startup founders who match each binary trait. The sparkline shows that share by startup founding year over the past 10 years.",
        "dataPaths": [
          "binaryVariables.years",
          "binaryVariables.variables"
        ]
      },
      "founders:team-interactions": {
        "title": "Team Interactions",
        "description": "Share of Israeli startup multi-founder teams prior connections: Any Interaction, Studied Together, Worked Together, Worked & Studied (both), Same Surname (a proxy for family ties). The sparkline shows that share by startup founding year over the past 10 years.",
        "dataPaths": [
          "teamIndicators.years",
          "teamIndicators.variables"
        ]
      },
      "founders:top-schools": {
        "title": "Top Schools by Founder Alumni",
        "description": "Top 15 schools ranked by the number of distinct Israeli startup founders who studied there. The percentage on each row is the share of all founders with known education that attended that school. A founder who studied at multiple schools is counted in each school but only once per school per founder.",
        "dataPaths": [
          "topSchools.totalFounders",
          "topSchools.items"
        ]
      },
      "founders:top-employers": {
        "title": "Top Employers by Founder Alumni",
        "description": "Top 15 prior employers ranked by the number of Israeli startup founders who worked there before founding their startup.  The percentage on each row is the share of all founders with known work history that worked at that employer counted once per employer per founder.",
        "dataPaths": [
          "topEmployers.totalFounders",
          "topEmployers.items"
        ]
      }
    }
  },
