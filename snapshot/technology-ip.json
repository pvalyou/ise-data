  "widgetMetadata": {
    "instructions": "Each entry under `widgets` describes one chart/widget rendered on this page of the Israeli Ecosystem dashboard. Descriptions are result-agnostic: they explain what the visualization shows and how to interpret it, not the specific numbers. The `dataPaths` array on each entry lists dot-notation paths inside this same JSON file where the underlying data for that widget lives (e.g. \"kpis.patentingStartups\" or \"ipIntensity.items\") When summarizing or answering questions about a number from this snapshot, locate the relevant widget(s) by `dataPaths` and quote the corresponding `description` to explain the metric. Widgets that have a 10 year trend usually show the total overall (across all years) and you get the exact data for each year in the past 10 years. The 10 year data do not add up to the total of course",
    "widgets": {
      "tech-ip:kpi-companies-with-patents": {
        "title": "Companies With Patents",
        "description": "Total number of Israeli startups that own at least one patent family (a group of related filings sharing the same invention). The sparkline shows the 10 year trend of new patenting companies by year of first filing.",
        "dataPaths": [
          "kpis.patentingStartups",
          "patentTrends.years",
          "patentTrends.patentingCompanies"
        ]
      },
      "tech-ip:kpi-patent-families": {
        "title": "Patent Families",
        "description": "Total count of patent families attributed to Israeli startups. A family groups together every filing of the same invention across jurisdictions, so it counts inventions rather than individual applications. The sparkline shows new families by earliest filing year in the past 10 years.",
        "dataPaths": [
          "kpis.patentFamilies",
          "patentTrends.years",
          "patentTrends.inventions"
        ]
      },
      "tech-ip:kpi-patent-filings": {
        "title": "Patent Filings",
        "description": "Total count of individual patent applications filed by Israeli startups. Each filing in each jurisdiction counts separately (one family typically produces several filings). The sparkline shows new filings per year in the past 10 years.",
        "dataPaths": [
          "kpis.patentFilings",
          "patentTrends.years",
          "patentTrends.patentFilings"
        ]
      },
      "tech-ip:patent-geography": {
        "title": "Patent Geography",
        "description": "Where Israeli startups protect their inventions. The interactive globe rotates to a hovered jurisdiction. The table lists the top jurisdictions ranked by number of Israeli companies filing there, alongside the count of patent families filed in that jurisdiction.",
        "dataPaths": [
          "patentGeography.items"
        ]
      },
      "tech-ip:ip-intensity": {
        "title": "Technology Patent Intensity",
        "description": "Each bubble is a technology family. The X axis is the number of Israeli companies developing in that area. The Y axis is patent families per company (patenting intensity). Bubble size is the number of those companies that actually patent. For example: the upper-right area has companies with many builders and patent heavily.",
        "dataPaths": [
          "ipIntensity.items"
        ]
      },
      "tech-ip:build-profile-donut": {
        "title": "Software vs Physical",
        "description": "Distribution of Israeli startups by what they build: pure software, pure physical (hardware, biotech, materials etc.), or a mix of both. Hover a slice to see its share of all startups.",
        "dataPaths": [
          "buildProfile.totalCompanies",
          "buildProfile.items"
        ]
      },
      "tech-ip:build-profile-efficiency": {
        "title": "Software Physical Patenting Frequency",
        "description": "How often each build profile (Software / Mixed / Physical) translates into actual patents. The horizontal bar shows the share of companies in that category that own at least one patent family. The dots represent patenting intensity: patent families per patenting company in that category.",
        "dataPaths": [
          "buildProfile.items"
        ]
      },
      "tech-ip:tech-family-treemap": {
        "title": "Most Built Technology Areas",
        "description": "Technology areas ranked by how many Israeli startups build in them. Tile size is proportional to the number of companies; the largest areas are filled with their family color, smaller ones are shown as outlines.",
        "dataPaths": [
          "ipIntensity.items"
        ]
      },
      "tech-ip:tech-trend-line": {
        "title": "Technology Area Trends",
        "description": "How the share of Israeli startups working in each top technology area has evolved over founding years. Each line is one area. The value at year Y is the share of companies founded in year Y whose primary technology falls in that area. The dashed tail marks the most recent year, which is still incomplete.",
        "dataPaths": [
          "techFamilyTrendSeries.years",
          "techFamilyTrendSeries.trending"
        ]
      }
    }
  },
